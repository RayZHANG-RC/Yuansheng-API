            "type": "notice",
            "message": "该问题需要预先加载合盘，请在用户输入八字后，加载合盘。"
        },
        "user_specification": {
            "required_inputs": [{}],
            "optional_inputs": [{
                    "type": "select",
                    "name": "物理距离的详细程度",
                    "options": ["同在一座城市", "同省不同市","同在一个国家，不同省份","同一大洲的不同国家","不同大洲"]
