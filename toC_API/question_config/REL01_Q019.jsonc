                {
                    "type": "select",
                    "name": "平均见面频率",
                    "options": ["天", "周", "月", "年"]
                }
            ]
        }
    },

    "quantitative_stage": {
        "domain_logic": "婚姻与配偶在命理中对应夫妻宫、疾厄宫及兄弟宫，关联亲密关系、健康、人际互动与家庭格局。高阶分析融合紫微三方四正、四化飞星、跨宫联动，并结合八字配偶星与六爻时机判断，以揭示配偶个性、能力、背景、婚运阶段。",
        "methods": [
            {
                "method_name": "六爻",
                "enabled": 1,
                "raw_palette":{},
                "risk_decision_logic":"远距离关系以卦中世应之静动状态、六合/六冲结构为主，辅以间爻、朱雀、父母爻配置判断沟通顺畅度与阻隔力。如世应俱静或六合，且朱雀/父母爻旺相，则较适合；若六冲或间爻发动，且朱雀被克，则易误解频发、沟通受阻。",
                "risk_assessment": [
                    "如果遇到世应俱静或六合卦象，则意味着关系稳定感情深厚，远距离关系可以维持",
                    "如果遇到朱雀或父母爻旺相得力，则意味着沟通能力强联系顺畅，远距恋情有保障",
                    "如果遇到用神生世且无刑冲，则意味着双方都有维持远距离关系的决心和能力",
                    "如果遇到世应俱动或六冲卦象，则意味着变数增多感情不稳，难以长期维持远距离",
                    "如果遇到朱雀或父母爻被克制，则意味着沟通障碍频发易生误会，存在断联风险",
                    "如果遇到间爻发动且带凶煞，则意味着可能有第三方干扰或环境阻隔，关系受威胁"
                ],
                "priority_remark": 1
            }
        ],
        "other_tips": ""
    },
    "qualitative_stage": {

        "law_and_regulation_requirements": [
            "距离越远，沟通频率与质量越关键",
            "距离程度影响维持难度，时间长度决定考验程度，沟通方式评估联系质量，见面频率关系感情稳定。"
