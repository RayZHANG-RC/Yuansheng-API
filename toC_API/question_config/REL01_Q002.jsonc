    "quantitative_stage": {
        "domain_logic": "婚姻与配偶在命理中对应夫妻宫、疾厄宫及兄弟宫，关联亲密关系、健康、人际互动与家庭格局。高阶分析融合紫微三方四正、四化飞星、跨宫联动，并结合八字配偶星与六爻时机判断，以揭示配偶个性、能力、背景、婚运阶段。",

        "methods": [
            {
                "method_name": "紫微斗数",
                "enabled": 1,
                "priority_remark": 2,
                "raw_palette": {},
                "risk_decision_logic": "以红鸾天喜和桃花星分析感情时机。红鸾主正缘姻缘，天喜主喜庆感情，天姚主肉体关系但易关系走偏进入无底线，咸池主异性缘分。若桃花星落入命或夫妻宫且无化忌刑害，并在流年或大运中被化禄或化科激活，表示在期待的时间范围内易遇新桃花。",
                "risk_assessment": [
                    "如果遇到流年冲克夫妻宫或桃花星受阻，则意味着桃花来临时间延后，感情机会较少",
                    "如果遇到煞星临命或夫妻宫破损，则意味着即使有桃花也质量不高，需谨慎选择",
                    "如果遇到大运不利或孤辰寡宿当令，则意味着感情运势低迷，桃花难以出现",
                    "如果遇到驿马受阻或人际宫位受损，则意味着社交机会有限，难以遇到合适对象",
                    "如果遇到红鸾入命或夫妻宫得力，则意味着正缘桃花即将到来，感情运势上扬",
                    "如果遇到天喜照会且贵人临门，则意味着感情发展喜悦顺利，桃花质量上乘",
                    "如果遇到天姚临身且魅力星动，则意味着个人桃花魅力增强，吸引力大增",
                    "如果遇到化忌落陷或煞星临夫妻宫，则意味着感情发展存在障碍，需留意烂桃花干扰"
                ]
            },
            {
                "method_name": "六爻",
                "enabled": 1,
