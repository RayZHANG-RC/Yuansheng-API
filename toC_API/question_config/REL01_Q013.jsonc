        "question_id": "REL01_Q013",
        "question_text": "我们适合在什么类型的地方约会？",
        "question_domain": "人际关系",
        "question_theme": "亲密关系",
        
                "llm_config": {
            // LLM configurations are now managed via unified CSV file:
            // - unified_llm_config.csv: Contains per-question LLM configurations for both quantitative and qualitative stages
            // This approach eliminates duplicate question files between GPT versions while allowing per-question LLM customization
            "config_source": "csv",
            "config_file": "unified_llm_config.csv"
        }
    },

    "user_init": {
        "user_specification": {
            "required_inputs": [
                {
                    "type": "text",
                    "name": "双方性格",
                    "placeholder": "请描述双方的性格特点..."
                },
                {
                    "type": "text",
                    "name": "季节时间",
                    "placeholder": "请描述约会的时间和季节..."
                },
                {
                    "type": "number",
                    "name": "预算范围",
                    "min": 0,
                    "placeholder": "请输入预算金额",
                    "unit": "元"
