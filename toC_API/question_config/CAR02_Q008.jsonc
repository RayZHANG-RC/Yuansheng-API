    "quantitative_stage": {
        // # === 领域内问题的基调 ===
        "domain_logic": "六爻以父母爻代表岗位权力与任命凭证，官鬼爻代表主管或决策权，财爻代表薪资待遇，世爻代表求测者自身状态。使用紫微斗数、八字评估职位，重心在官禄与命宫的三方四正格局。",
        // # === 术数盘式数据 ===
        "methods": [
            {
                "method_name": "紫微斗数",
                "enabled": 1,
                "raw_palette": {},
                "priority_remark": 1,
                "risk_decision_logic": "紫微斗数中，交友宫主团队互动氛围，命宫体现个体在团队中定位，官禄宫显领导/职责评价。通过三宫联动分析吉凶格局、四化变化与星曜状态，为团队协作提供策略参考。交友宫、命宫、官禄宫可观团队氛围，若吉星庙旺，主团队和谐。若化忌冲命宫，则需防范团队矛盾。若交友宫吉星如天同、天机、红鸾且无煞冲，则团队氛围融洽；命宫若被交友宫吉化入庙，说明你容易获得团队接纳；官禄宫若有化权、化禄或武曲、天府等星曜且三方四正联动，说明你在团队中具备职责权限与支持。若交友宫化忌或遭冲，则说明需防范团队摩擦或角色边缘化。",
                "risk_assessment": [
                    "如果遇到交友宫化忌冲克命宫，则意味着团队矛盾激烈，个人易成为矛盾焦点需谨慎防范",
                    "如果遇到命宫与官禄宫三方四正联动强劲，则意味着团队配合度高，应担当沟通桥梁角色",
                    "如果遇到交友宫吉星庙旺且无煞冲，则意味着团队互动良好，适合发挥协作领导能力",
                    "如果遇到官禄宫三方四正星曜庙旺，则意味着职责清晰明确，工作贡献受到重视认可",
                    "如果遇到交友宫遭化煞或被四煞冲破，则意味着存在团队摩擦或人际隔阂，需主动化解",
                    "如果遇到官禄宫化忌或主星陷地，则意味着职责可能被忽视或承受不必要的工作压力",
                    "如果遇到天同天机红鸾等吉星入交友宫，则意味着团队氛围融洽，个人魅力能带动团队士气"
                ]
            }
