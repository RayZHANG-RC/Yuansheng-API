{
    "question_metadata": {
        "analysis_version": "V0.0.1",
        "question_id": "DEV01_Q002",
        "question_text": "我适合在什么时候进行重要的个人能力提升？",
        "question_domain": "个人发展",
        "question_theme": "个人提升",

                "llm_config": {
            // LLM configurations are now managed via unified CSV file:
