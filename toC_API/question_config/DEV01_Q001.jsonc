                }
            ]
        }
    },

    "quantitative_stage":{

        "domain_logic": "个人竞争力品格首看命盘格局，次看当下所在大运流年，末看六爻。需鼓励个人努力与投入。",

        "methods": [
            {
                "method_name": "八字",
                "enabled": 1,
                "raw_palette": {},
                "priority_remark": 2,
                "risk_decision_logic": "以命局十神格局、用神忌神、原局与大运流年交互等高级子平法进行剖析。若日主得令、格局成象（如从强、从弱、专旺、化格等），结合食伤、印星、官杀、财星、比劫配置细分主攻方向；偏重分析如食神伤官透出得力者主才艺创意，印绶有力主学术研究、资源整合，官杀清纯主管理与领导，财星聚合主经营投资。盲派断层法可发现隐藏竞争力，大运流年如见用神透现，则阶段性优势突出。最终以用神力量与忌神制化为评估基准，判定个人核心优势与可持续发展潜力。",
                "risk_assessment": [
                    "如果遇到食神伤官格局清高且得用，则意味着创意表达艺术才华突出，适宜发展创新类岗位",
                    "如果遇到印绶有力且通根透干，则意味着学识深厚资源整合能力强，适合学术研究教育培训领域",
                    "如果遇到官星清纯且为用神得令，则意味着组织管理执行力强，宜于担任领导管理职位",
                    "如果遇到财星得地且聚合有情，则意味着商业头脑敏锐，擅长经营投资与财富增长",
                    "如果遇到比劫成局且与财星良性互动，则意味着团队协作与资源调动能力强",
                    "如果遇到特殊格局如从格化格成立，则意味着在极端优势领域突出但须防环境失衡风险",
                    "如果遇到大运流年用神得令透现，则意味着优势领域会有突破性发展机遇"
                ]
            },
            {
                "method_name": "紫微斗数",
                "enabled": 1,
                "raw_palette": {},
                "priority_remark": 1,
                "risk_decision_logic": "综合命宫主星（定基因）、三方四正（命身官福联动）、四化（权禄科忌交错）、星曜组合与跨宫结构解读，结合文昌、文曲、化科、化权、天机、天梁等专业星曜分析。命宫主星判定本质能力，官禄宫分析职业方向，身宫及迁移宫揭示外在表现力与应变能力，福德宫体现内在智慧与情商。三方四正如有吉星聚会，优势能力易外化；如遇煞星夹制，则需化煞为用。特殊连线法与飞星法则，用以发现跨界、整合型竞争力。四化同宫/对照主权威、成就与声誉。科星（文昌文曲化科）主学术、技术与创造；权星主领导管理；禄星主资源整合与财富。融合大限、小限流转，判断人生阶段性竞争力变化。",
                "risk_assessment": [
                    "如果遇到命宫主星庙旺且三方得力，则意味着先天优势明显，如天机主机智谋略太阳主领导魅力巨门主口才天梁主贵人运",
                    "如果遇到三方四正文星聚会且化科加临，则意味着学术写作技术创造能力卓越，专业声誉突出",
                    "如果遇到官禄宫吉化且星曜得力，则意味着职业发展顺畅，易获社会认可和权威地位",
                    "如果遇到迁移宫星曜有力且吉化，则意味着外交表达变通应对能力强，适合对外发展",
                    "如果遇到福德宫星曜明朗且无煞冲，则意味着内在智慧心理素质高，抗压能力强",
                    "如果遇到四化同宫或跨宫联动良好，则意味着领域权威突出，多元整合与横向发展能力佳"
                ]
            },
            {
                "method_name": "六爻",
                "enabled": 1,
                "raw_palette": {},
                "priority_remark": 3,
                "risk_decision_logic": "六爻占核心竞争力，首观青龙所持之爻及动静。青龙持世或持用神，主自身才干显赫，有独立发展空间。青龙动爻得日月建生扶，更主才艺突出、贵人助力。若青龙持财、持官为用，主商业、管理能力强；持印为用主学业与资源整合。分析动静变化，若青龙发动化生或化进神，主能力可转化提升，易突破自限；若受制化退，则需警惕被动与瓶颈。世应爻比合、六亲六兽装载细分能力方向（如兄弟主协作，比肩主竞争，父母主学业，子孙主创新）。同时以月建日建、用神旺衰、多爻合动、变卦关系，判断实际竞争力发挥与阶段性提升空间。",
                "risk_assessment": [
                    "如果遇到青龙持世或持用神且得力，则意味着才华外显竞争力强，善于主动争取资源和机遇",
                    "如果遇到青龙发动且得日月建生扶，则意味着天赋易被激发，发展空间大潜力可期",
                    "如果遇到青龙持财爻旺相，则意味着商业能力突出，持官爻主领导管理，持印爻主学业技术专长",
                    "如果遇到青龙遇吉化如化进神化生，则意味着能力可转化升级，适应性和成长性强",
                    "如果遇到六亲六兽装载各有所司，则意味着创新协作管理等不同能力板块可细化发展",
                    "如果遇到青龙受制或化退神，则意味着优势易受环境影响，需谨慎把握时机避免被动"
                ]
            }
        ],
        "other_tips": "综合采用八字格局、紫微三方四正、六爻青龙动爻等多维术数高阶法，评估智力才华、情商社交、领导管理、专业技能、创新创造等能力。每一方法都有独特评估机制，务必结合具体盘式、人生阶段及实际环境分析，避免孤立判断。"
    },

