    "quantitative_stage": {
        "domain_logic": "婚姻与配偶在命理中对应夫妻宫、疾厄宫及兄弟宫，关联亲密关系、健康、人际互动与家庭格局。高阶分析融合紫微三方四正、四化飞星、跨宫联动，并结合八字配偶星与六爻时机判断，以揭示配偶个性、能力、背景、婚运阶段。",
        "methods": [
            {
                "method_name": "小六壬",
                "enabled": 1,
                "raw_palette": {},
                "risk_decision_logic": "以“大安、留连、速喜、赤口、小吉、空亡”掌诀判断当前时间之六神状态，再根据三合局中“财爻”（代表地点）与“子孙爻”（代表人和）是否得力，辅助分析地点与人物互动的匹配度。大安/速喜/小吉为吉象，大吉氛围；赤口/留连/空亡为凶象，需谨慎。",
                "risk_assessment": [
                    "如果遇到大安或小吉六神当值，则意味着约会氛围舒适互动自然，是吉祥相遇结果美好",
                    "如果遇到速喜六神临门，则意味着能快速拉近关系，但效率与节奏略快需把握分寸",
                    "如果遇到财爻子孙爻得力且天干地支和谐，则意味着地点与人物互动匹配度高，约会成功",
                    "如果遇到赤口六神主事，则意味着可能发生口舌冲突，或处在双方内耗中，结果不佳",
                    "如果遇到留连或空亡凶象，则意味着气氛僵滞或空转，约会效果受限难有进展",
                    "如果遇到时宫天干地支属性凶煞，则意味着环境配色状态氛围不利，影响约会质量"
                ],
                "priority_remark": 1
            }
        ],
        "other_tips": "非常注意该宫的天干地支，相关的天干地支之属性同样指示环境的配色、状态、氛围。"
    },

