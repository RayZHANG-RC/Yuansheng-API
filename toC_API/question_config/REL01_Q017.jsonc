{
    "question_metadata": {
        "analysis_version": "V0.0.1",
        "question_id": "REL01_Q017",
        "question_text": "我适合给TA送什么样的礼物？",
        "question_domain": "人际关系",
        "question_theme": "亲密关系",

                "llm_config": {
            // LLM configurations are now managed via unified CSV file:
