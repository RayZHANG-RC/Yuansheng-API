{
    "question_metadata": {
        "analysis_version": "V0.0.1",
        "question_id": "CAR03_Q007",
        "question_text": "我如果现在创业，会面临哪些困难？",
        "question_domain": "职业发展",
        "question_theme": "创业主本人",

                "llm_config": {
            // LLM configurations are now managed via unified CSV file:
            // - unified_llm_config.csv: Contains per-question LLM configurations for both quantitative and qualitative stages
            // This approach eliminates duplicate question files between GPT versions while allowing per-question LLM customization
            "config_source": "csv",
            "config_file": "unified_llm_config.csv"
        }
    },

    "user_init": {

        "ui_pop_up": {
            "type": "notice",
            "message": "困难指的是会对自身造成制约、阻滞；风险指的是会对自身造成伤害。"
        },

        "user_specification": {
            "required_inputs": [
                {
                    "type": "text",
                    "name": "创业方向",
                    "placeholder": "请描述您的创业方向、行业领域等"
                },
                {
                    "type": "text",
                    "name": "资源状况",
                    "placeholder": "请描述您的资源状况、资金、人脉等"
                }
            ],
            "optional_inputs": [
                {
                    "type": "text",
                    "name": "其他具体描述",
                    "placeholder": "请详细描述其他相关信息"
                }
            ]
        }
    },

    "quantitative_stage":{

        "domain_logic": "六爻以父母爻代表岗位权力与任命凭证，官鬼爻代表主管或决策权，财爻代表薪资待遇，世爻代表求测者自身状态。使用紫微斗数、八字评估职位，重心在官禄与命宫的三方四正格局。",

        "methods": [
            {
                "method_name": "紫微斗数",
                "enabled": 1,
                "raw_palette":{},
                "risk_decision_logic":"命、财、官等关键宫位遭煞忌冲破，尤重化忌落点与飞星轨迹，仆役宫化忌冲财帛或事业主受人拖累。命、财、官等关键宫位若遭擎羊、陀罗、火铃等四煞冲破，各有其忧。尤重化忌的落点与飞星轨迹，例如仆役宫化忌冲我财帛或事业，主受朋友、合伙人所累而破财败事。",
                "risk_assessment": [
                    "如果遇到命宫化忌冲破或主星失陷，则意味着自身决断力受阻，容易陷入内耗和迷茫状态",
                    "如果遇到财帛宫被煞星冲破或化忌，则意味着资金链不稳定，面临断裂或投资失误风险",
                    "如果遇到官禄宫落陷或煞星云集，则意味着政策监管成为障碍，合规压力巨大",
                    "如果遇到仆役宫化忌或受克，则意味着合作团队关系中隐藏风险，易生内部矛盾",
                    "如果遇到迁移宫受损或化忌，则意味着市场拓展困难，外部发展阻力重重",
                    "如果遇到疾厄宫不佳或化忌，则意味着身心健康受创业压力影响，需注意劳逸结合",
                    "如果遇到田宅宫破损，则意味着基础资产不稳，创业过程中可能面临根基动摇"
                ],
                "priority_remark": 1
            }
        ],
        "other_tips": "分别从资金、人脉、团队及政策环境等维度拆解，识别当前资源弱环并提前布局；如资金链、核心合伙风险、行政许可等问题。"
    },

    "qualitative_stage":{
        "law_and_regulation_requirements": [
            "请结合实际情况慎重判断，涉及创业政策请咨询专业人士"
        ],
        "ui_tips": "V2.0 可在界面显示“风险雷达图”，四象限分别为资金、合伙、政策、执行难点，评级为高/中/低。",
        "follow_up_questions": [
            {}
        ]
    },
    "synastry": {
        "required": false
    }
