{
    "question_metadata": {
        "analysis_version": "V0.0.1",
        "question_id": "HLT01_Q002",
        "question_text": "我应该如何调整我的生活方式到一个合适我的舒适状态？",
        "question_domain": "健康生活",
        "question_theme": "健康投资",

                "llm_config": {
            // LLM configurations are now managed via unified CSV file:
